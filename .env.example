# ═══════════════════════════════════════════════════════════════
# Attack Chain Autopsy Engine — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── AI / LLM API Keys ─────────────────────────────────────────
# Anthropic API key — used by Claude Sonnet for agent reasoning
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API key — used for text-embedding-3-small embeddings in ChromaDB
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Neo4j Graph Database ──────────────────────────────────────
# Connection URI for Neo4j Bolt protocol
# Docker: bolt://localhost:7687
# Remote: neo4j+s://<host>:7687
NEO4J_URI=bolt://localhost:7687

# Neo4j authentication credentials
# Docker default user is 'neo4j' — change password before production
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── ChromaDB Vector Store ─────────────────────────────────────
# Local filesystem path for ChromaDB persistence
# Docker: /app/chroma_db (maps to named volume)
# Local dev: ./chroma_db
CHROMA_PATH=./chroma_db

# ── MITRE ATT&CK STIX Data ───────────────────────────────────
# Path to the MITRE ATT&CK Enterprise STIX bundle JSON
# Download from: https://github.com/mitre/cti (enterprise-attack/enterprise-attack.json)
# Or let setup_demo.sh download it automatically
MITRE_ATTACK_STIX_PATH=./data/mitre/enterprise-attack.json

# ── Application Settings ──────────────────────────────────────
# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Demo mode: true = pre-loads AIIMS and CBSE scenario data on startup
# false = clean slate, load data via API or scripts
DEMO_MODE=true

# ── Autonomous Response Safety Gate ───────────────────────────
# Blast radius threshold (0.0–1.0) for auto-approval of SOAR playbooks
# Actions affecting <THRESHOLD fraction of hosts execute automatically
# Actions affecting ≥THRESHOLD require human approval
# Default 0.3 = auto-execute if <30% of fleet impacted
# Set to 0.0 to require human approval for ALL actions
# Set to 1.0 to fully autonomous (NOT RECOMMENDED for production)
BLAST_RADIUS_AUTO_THRESHOLD=0.3

# ── Data Directories ──────────────────────────────────────────
# Root path for synthetic scenario data
DATA_DIR=./data/synthetic

# ── Security ─────────────────────────────────────────────────
# Secret key for JWT token signing (generate with: openssl rand -hex 32)
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# JWT token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Frontend Configuration ────────────────────────────────────
# Backend API URL (used by Vite build and dev server)
VITE_API_URL=http://localhost:8000
VITE_NEO4J_URL=http://localhost:7474
