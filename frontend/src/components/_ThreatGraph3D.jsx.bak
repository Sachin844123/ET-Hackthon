import React, { useRef, useState, useCallback } from 'react';
import ForceGraph3D from 'react-force-graph-3d';
import * as THREE from 'three';
import { motion, AnimatePresence } from 'framer-motion';
import { Focus, Maximize, Target } from 'lucide-react';

const NODE_COLORS = {
  HOST: '#00b4d8',
  ACCOUNT: '#f59e0b',
  IP: '#7c3aed',
  DOMAIN: '#ec4899',
  PROCESS: '#6b7280'
};

const EDGE_COLORS = {
  COMMUNICATED_WITH: '#334155',
  AUTHENTICATED_AS: '#f59e0b',
  EXECUTED_PROCESS: '#7c3aed',
  LATERAL_MOVEMENT: '#ef4444' 
};

export default function ThreatGraph3D({ graph_nodes = [], graph_edges = [], incident_id }) {
  const fgRef = useRef();
  const [selectedNode, setSelectedNode] = useState(null);
  const [selectedEdge, setSelectedEdge] = useState(null);
  const [timeWindow, setTimeWindow] = useState(22);
  const [onlyCompromised, setOnlyCompromised] = useState(false);
  const [nodeTypes, setNodeTypes] = useState({
    HOST: true, ACCOUNT: true, IP: true, DOMAIN: true, PROCESS: true
  });

  const handleNodeClick = useCallback(node => {
    setSelectedNode(node);
    setSelectedEdge(null);
    const distance = 80;
    const distRatio = 1 + distance/Math.hypot(node.x, node.y, node.z);
    fgRef.current.cameraPosition(
      { x: node.x * distRatio, y: node.y * distRatio, z: node.z * distRatio }, 
      node, 
      2000 // slower, more cinematic camera move
    );
  }, [fgRef]);

  const handleEdgeClick = useCallback(edge => {
    setSelectedEdge(edge);
    setSelectedNode(null);
  }, []);

  const resetCamera = useCallback(() => {
    setSelectedNode(null);
    setSelectedEdge(null);
    fgRef.current.cameraPosition({ x: 0, y: 0, z: 300 }, { x: 0, y: 0, z: 0 }, 2500);
  }, [fgRef]);

  const focusAttackPath = useCallback(() => {
    const compNodes = graph_nodes.filter(n => n.is_compromised);
    if (compNodes.length > 0) {
      fgRef.current.cameraPosition({ x: compNodes[0].x, y: compNodes[0].y, z: 120 }, compNodes[0], 2500);
    }
  }, [graph_nodes]);

  const filteredNodes = graph_nodes.filter(node => {
    if (!nodeTypes[node.type]) return false;
    if (onlyCompromised && !node.is_compromised) return false;
    
    if (incident_id?.includes('aiims')) {
      if (timeWindow < 3 && node.id === 'AIIMS-PATIENT-MGMT-01') return false;
      if (timeWindow < 7 && node.id === 'AIIMS-FILE-SRV-02') return false;
      if (timeWindow < 12 && (node.type === 'IP' || node.type === 'DOMAIN')) return false;
    }
    return true;
  });

  const filteredNodeIds = new Set(filteredNodes.map(n => n.id));
  const filteredEdges = graph_edges.filter(edge => 
    filteredNodeIds.has(typeof edge.source === 'object' ? edge.source.id : edge.source) &&
    filteredNodeIds.has(typeof edge.target === 'object' ? edge.target.id : edge.target)
  );

  return (
    <motion.div 
      initial={{ opacity: 0, scale: 0.98 }}
      animate={{ opacity: 1, scale: 1 }}
      transition={{ duration: 0.6 }}
      className="relative w-full h-[600px] bg-[#030712] rounded-xl border border-slate-700/50 shadow-2xl overflow-hidden flex"
    >
      
      {/* Controls Panel (Top Left) */}
      <motion.div 
        initial={{ x: -50, opacity: 0 }}
        animate={{ x: 0, opacity: 1 }}
        transition={{ delay: 0.4, type: 'spring' }}
        className="absolute top-4 left-4 z-10 cyber-card p-4 text-xs w-64 shadow-2xl"
      >
        <h3 className="text-white font-bold mb-3 tracking-widest border-b border-slate-800/80 pb-2 font-mono flex items-center gap-2">
          <Target className="w-4 h-4 text-cyan-400" /> GRAPH CONTROLS
        </h3>
        
        <div className="mb-5">
          <div className="flex justify-between text-[10px] text-slate-400 font-bold mb-2 font-mono uppercase tracking-wider">
            <span>Day Threshold</span>
            <span className="text-cyan-400 bg-cyan-950/30 px-1.5 py-0.5 rounded border border-cyan-900/50">Day {timeWindow}</span>
          </div>
          <input type="range" min="1" max="22" value={timeWindow} 
                 onChange={e => setTimeWindow(parseInt(e.target.value))}
                 className="w-full accent-cyan-500 cursor-pointer" />
          <div className="flex justify-between text-[9px] text-slate-600 mt-1.5 font-mono">
            <span>T-21 (Start)</span>
            <span>T-0 (Impact)</span>
          </div>
        </div>

        <div className="mb-4 space-y-1">
          <label className="flex items-center text-[11px] font-mono text-slate-300 cursor-pointer hover:text-white transition-colors group">
            <input type="checkbox" checked={onlyCompromised} onChange={e => setOnlyCompromised(e.target.checked)} className="mr-2 accent-red-500" />
            <span className="group-hover:text-red-400 transition-colors">Show Only Compromised</span>
          </label>
        </div>

        <div className="mb-5 grid grid-cols-2 gap-y-2 gap-x-1 text-[10px] font-mono border-t border-slate-800/80 pt-4">
          {Object.keys(NODE_COLORS).map(type => (
            <label key={type} className="flex items-center text-slate-400 cursor-pointer hover:text-slate-200 transition-colors">
              <input type="checkbox" checked={nodeTypes[type]} 
                     onChange={e => setNodeTypes(p => ({...p, [type]: e.target.checked}))} 
                     className="mr-1.5 accent-cyan-500" />
              <span style={{ color: NODE_COLORS[type], textShadow: `0 0 5px ${NODE_COLORS[type]}` }}>●</span> &nbsp;{type}
            </label>
          ))}
        </div>

        <div className="flex flex-col gap-2 pt-2 border-t border-slate-800/80">
          <button onClick={resetCamera} className="bg-slate-900/80 hover:bg-slate-800 text-slate-300 py-2 rounded font-bold tracking-widest transition-all border border-slate-700/50 font-mono text-[9px] flex justify-center items-center gap-1.5 hover:shadow-[0_0_10px_rgba(255,255,255,0.05)]">
            <Maximize className="w-3 h-3" /> RESET CAMERA
          </button>
          <button onClick={focusAttackPath} className="bg-red-950/40 hover:bg-red-900/60 text-red-400 py-2 rounded font-bold tracking-widest transition-all border border-red-800/60 shadow-[0_0_15px_rgba(239,68,68,0.15)] font-mono text-[9px] flex justify-center items-center gap-1.5 hover:shadow-[0_0_20px_rgba(239,68,68,0.3)]">
            <Focus className="w-3 h-3" /> FOCUS ATTACK PATH
          </button>
        </div>
      </motion.div>

      {/* Detail Panel (Right) */}
      <AnimatePresence>
        {(selectedNode || selectedEdge) && (
          <motion.div 
            initial={{ x: 50, opacity: 0 }}
            animate={{ x: 0, opacity: 1 }}
            exit={{ x: 50, opacity: 0 }}
            transition={{ type: 'spring', damping: 20 }}
            className="absolute top-4 right-4 z-10 cyber-card p-5 text-sm w-80 shadow-2xl backdrop-blur-xl border-l-4"
            style={{ borderLeftColor: selectedNode ? (selectedNode.is_compromised ? '#ef4444' : NODE_COLORS[selectedNode.type]) : (selectedEdge?.anomalous ? '#ef4444' : '#06b6d4') }}
          >
            <button onClick={() => { setSelectedNode(null); setSelectedEdge(null); }} className="absolute top-3 right-4 text-slate-500 hover:text-white transition-colors">✕</button>
            
            {selectedNode && (
              <>
                <div className="flex items-center gap-2 mb-2">
                  <span className="w-2 h-2 rounded-full shadow-[0_0_8px_currentColor]" style={{ backgroundColor: NODE_COLORS[selectedNode.type] || '#ccc', color: NODE_COLORS[selectedNode.type] || '#ccc' }} />
                  <span className="text-[10px] tracking-widest text-slate-400 font-bold uppercase font-mono">{selectedNode.type}</span>
                </div>
                <h2 className="text-white font-bold text-base mb-4 break-all font-mono pb-3 border-b border-slate-800/80">{selectedNode.name || selectedNode.id}</h2>
                
                {selectedNode.is_compromised && (
                  <div className="bg-red-950/60 text-red-400 border border-red-500/50 px-3 py-1.5 rounded text-[10px] font-bold mb-4 inline-flex items-center gap-2 shadow-[0_0_15px_rgba(239,68,68,0.25)] font-mono tracking-wider">
                    <span className="w-1.5 h-1.5 rounded-full bg-red-500 animate-ping" />
                    COMPROMISED NODE
                  </div>
                )}
                
                <div className="space-y-4 mt-2 font-mono">
                  <div>
                    <div className="text-[9px] text-slate-500 uppercase tracking-widest font-bold mb-1">Criticality</div>
                    <div className="text-slate-200 text-xs bg-slate-900/50 px-2 py-1 rounded inline-block border border-slate-800/50">{selectedNode.criticality || 'NORMAL'}</div>
                  </div>
                  {selectedNode.is_compromised && (
                    <div>
                      <div className="text-[9px] text-slate-500 uppercase tracking-widest font-bold mb-1">Observed Techniques</div>
                      <ul className="text-cyan-300 text-[10px] list-disc pl-4 mt-1 space-y-1.5 bg-cyan-950/20 p-2.5 rounded border border-cyan-900/30">
                        <li>T1078 Valid Accounts</li>
                        <li>T1021.002 SMB Shares</li>
                      </ul>
                    </div>
                  )}
                </div>
              </>
            )}

            {selectedEdge && (
              <>
                <div className="text-[9px] tracking-widest text-slate-500 mb-1 font-bold font-mono uppercase">RELATIONSHIP EDGE</div>
                <h2 className={`font-bold mb-4 border-b border-slate-800/80 pb-3 text-sm font-mono ${selectedEdge.anomalous ? 'text-red-400 neon-glow-text-red' : 'text-cyan-400'}`}>
                  {selectedEdge.type || 'CONNECTED_TO'}
                </h2>
                
                <div className="space-y-4 text-xs font-mono">
                  <div>
                    <div className="text-[9px] text-slate-500 uppercase tracking-widest font-bold mb-1">Source</div>
                    <div className="text-slate-300 bg-slate-900/50 p-2 rounded border border-slate-800/50 break-all text-[10px]">{selectedEdge.source?.id || selectedEdge.source}</div>
                  </div>
                  <div className="flex justify-center text-slate-600">↓</div>
                  <div>
                    <div className="text-[9px] text-slate-500 uppercase tracking-widest font-bold mb-1">Target</div>
                    <div className="text-slate-300 bg-slate-900/50 p-2 rounded border border-slate-800/50 break-all text-[10px]">{selectedEdge.target?.id || selectedEdge.target}</div>
                  </div>
                  {selectedEdge.anomalous && (
                    <motion.div 
                      initial={{ scale: 0.95 }}
                      animate={{ scale: 1 }}
                      className="mt-5 bg-amber-950/40 border border-amber-500/50 p-3 rounded shadow-[0_0_15px_rgba(245,158,11,0.15)]"
                    >
                      <span className="text-amber-400 font-bold block mb-1.5 text-[10px] tracking-wider flex items-center gap-1.5">
                        <span className="w-1.5 h-1.5 bg-amber-500 rounded-full animate-pulse" /> ANOMALY DETECTED
                      </span>
                      <span className="text-amber-200/70 text-[9px] leading-relaxed block bg-amber-950/50 p-1.5 rounded">Score: 0.89 | Volume spike + Off-hours</span>
                    </motion.div>
                  )}
                </div>
              </>
            )}
          </motion.div>
        )}
      </AnimatePresence>

      {/* ForceGraph3D Canvas */}
      <div className="flex-1 cursor-crosshair relative z-0">
        <ForceGraph3D
          ref={fgRef}
          graphData={{ nodes: filteredNodes, links: filteredEdges }}
          nodeRelSize={4}
          nodeVal={node => Math.max(4, Math.min(20, node.val || 4))}
          nodeColor={node => NODE_COLORS[node.type] || '#ffffff'}
          nodeResolution={32} /* Higher resolution for smoother spheres */
          nodeOpacity={0.9}
          linkWidth={edge => edge.anomalous ? 2.5 : 0.8}
          linkColor={edge => edge.anomalous ? EDGE_COLORS.LATERAL_MOVEMENT : EDGE_COLORS.COMMUNICATED_WITH}
          linkDirectionalParticles={edge => edge.anomalous ? 6 : (edge.type ? 2 : 0)}
          linkDirectionalParticleSpeed={edge => edge.anomalous ? 0.02 : 0.008}
          linkDirectionalParticleWidth={edge => edge.anomalous ? 3 : 1.5}
          linkDirectionalParticleColor={edge => edge.anomalous ? '#f87171' : '#64748b'}
          onNodeClick={handleNodeClick}
          onLinkClick={handleEdgeClick}
          backgroundColor="#030712"
          showNavInfo={false}
          nodeThreeObject={node => {
            const size = Math.max(4, Math.min(20, node.val || 4));
            const group = new THREE.Group();
            
            // Core sphere with emissive properties
            const coreGeometry = new THREE.SphereGeometry(size, 24, 24);
            const color = NODE_COLORS[node.type] || '#ffffff';
            const coreMaterial = new THREE.MeshPhongMaterial({
              color: color,
              emissive: color,
              emissiveIntensity: node.is_compromised ? 0.6 : 0.2,
              transparent: true,
              opacity: 0.9,
              shininess: 100
            });
            const coreMesh = new THREE.Mesh(coreGeometry, coreMaterial);
            group.add(coreMesh);

            // Animated Halo for compromised nodes
            if (node.is_compromised) {
              // Outer wireframe sphere
              const haloGeometry = new THREE.SphereGeometry(size * 1.6, 16, 16);
              const haloMaterial = new THREE.MeshBasicMaterial({ 
                color: '#ef4444', 
                transparent: true, 
                opacity: 0.4,
                wireframe: true
              });
              const haloMesh = new THREE.Mesh(haloGeometry, haloMaterial);
              
              // Simple rotation animation attached to user data to be updated in render loop (advanced feature, but we'll add static rotation for now)
              haloMesh.rotation.x = Math.random() * Math.PI;
              haloMesh.rotation.y = Math.random() * Math.PI;
              
              group.add(haloMesh);

              // Inner solid glow
              const innerGlowGeo = new THREE.SphereGeometry(size * 1.3, 24, 24);
              const innerGlowMat = new THREE.MeshBasicMaterial({
                color: '#ef4444',
                transparent: true,
                opacity: 0.15,
                blending: THREE.AdditiveBlending
              });
              const innerGlowMesh = new THREE.Mesh(innerGlowGeo, innerGlowMat);
              group.add(innerGlowMesh);
            }
            return group;
          }}
        />
        {/* CSS Overlay for vignette/scanline effect over the canvas */}
        <div className="absolute inset-0 pointer-events-none rounded-xl" style={{
          background: 'radial-gradient(circle at center, transparent 30%, rgba(3,7,18,0.8) 100%)',
          boxShadow: 'inset 0 0 50px rgba(0,0,0,0.8)'
        }} />
        <div className="absolute inset-0 pointer-events-none scanline-overlay opacity-30 mix-blend-overlay" />
      </div>
    </motion.div>
  );
}
