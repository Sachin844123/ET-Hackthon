    },
    {
      "src": "/health",
      "dest": "https://et-hackthon-backend-oic4.onrender.com/health"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
